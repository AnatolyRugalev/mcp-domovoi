# domovoi configuration -- copy to /etc/domovoi/domovoi.env and edit.
# chmod 600 and chown root:root; it holds the auth token.

# Required. Bearer token clients must present. Generate one with:
#   openssl rand -hex 32
DOMOVOI_TOKEN=change-me

# Address to listen on. LAN-only; TLS is the gateway's job.
#DOMOVOI_LISTEN=0.0.0.0:8811

# URL path of the MCP endpoint. Set to something like /mcp-<random> as a
# fallback auth layer for clients that cannot send headers.
#DOMOVOI_PATH=/mcp

# Colon-separated absolute path prefixes the file tools (read_file,
# write_file, edit_file) may touch. Default "/" = unrestricted.
# NOTE: run_command is NOT restricted by this -- commands can touch anything
# the unix user can. The service user is the real privilege boundary.
#DOMOVOI_ALLOWED_DIRS=/home/toly:/etc:/opt
